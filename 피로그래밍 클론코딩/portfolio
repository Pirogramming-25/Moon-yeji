<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>포트폴리오 | 피로그래밍</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; }
    body {
      font-family: 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif;
      background: #f5f5f5;
      color: #222;
      min-width: 350px;
    }
    nav {
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      height: 60px;
    }
    .nav-logo { font-size: 1.25rem; font-weight: 800; color: #4f46e5; letter-spacing: -0.5px; }
    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a { text-decoration: none; color: #555; font-size: 0.9rem; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: #4f46e5; }
    .nav-links a.active { color: #4f46e5; font-weight: 700; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
    .hamburger span { display: block; width: 22px; height: 2px; background: #333; border-radius: 2px; }
    .page-header { background: #4f46e5; color: #fff; padding: 48px 24px 40px; text-align: center; }
    .page-header h1 { font-size: 2rem; font-weight: 800; margin-bottom: 8px; }
    .page-header p { font-size: 1rem; opacity: 0.85; }
    .tabs { display: flex; justify-content: center; gap: 8px; padding: 28px 24px 0; }
    .tab-btn { padding: 8px 22px; border-radius: 20px; border: 2px solid #d1d5db; background: #fff; color: #555; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .tab-btn.active { background: #4f46e5; border-color: #4f46e5; color: #fff; }
    .tab-btn:hover:not(.active) { border-color: #4f46e5; color: #4f46e5; }
    .portfolio-section { max-width: 1200px; margin: 0 auto; padding: 32px 24px 64px; }
    .portfolio-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .portfolio-card {
      background: #fff; border-radius: 14px; overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      cursor: pointer; display: flex; flex-direction: column;
    }
    .portfolio-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(79,70,229,0.13); }
    .card-img-wrap { overflow: hidden; aspect-ratio: 16/9; background: #e5e7eb; position: relative; }
    .card-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s ease; display: block; }
    .portfolio-card:hover .card-img-wrap img { transform: scale(1.07); }
    .card-body { padding: 16px 18px 20px; flex: 1; display: flex; flex-direction: column; }
    .card-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
    .tag { font-size: 0.72rem; font-weight: 600; padding: 3px 9px; border-radius: 10px; background: #ede9fe; color: #5b21b6; }
    .tag.green { background: #d1fae5; color: #065f46; }
    .tag.blue { background: #dbeafe; color: #1d4ed8; }
    .tag.orange { background: #ffedd5; color: #c2410c; }
    .card-title { font-size: 1rem; font-weight: 700; color: #111; margin-bottom: 6px; line-height: 1.4; }
    .card-desc { font-size: 0.82rem; color: #6b7280; line-height: 1.6; flex: 1; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; padding: 12px 18px 16px; border-top: 1px solid #f3f4f6; }
    .card-members { font-size: 0.78rem; color: #9ca3af; }
    .card-hamburger { display: flex; flex-direction: column; gap: 4px; padding: 2px; }
    .card-hamburger span { display: block; width: 18px; height: 2px; background: #9ca3af; border-radius: 2px; transition: transform 0.25s, width 0.25s, background 0.25s; transform-origin: center; }
    .portfolio-card:hover .card-hamburger { gap: 2px; }
    .portfolio-card:hover .card-hamburger span:nth-child(1) { transform: scaleX(0.6); background: #4f46e5; }
    .portfolio-card:hover .card-hamburger span:nth-child(2) { transform: scaleX(0.85); background: #4f46e5; }
    .portfolio-card:hover .card-hamburger span:nth-child(3) { transform: scaleX(0.5); background: #4f46e5; }
    @media (max-width: 900px) { .portfolio-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; } }
    @media (max-width: 640px) { .portfolio-grid { grid-template-columns: 1fr; gap: 16px; } .page-header h1 { font-size: 1.5rem; } .nav-links { display: none; } .hamburger { display: flex; } }
    @media (max-width: 480px) { .nav-inner { padding: 0 16px; } .portfolio-section { padding: 20px 14px 48px; } .card-body { padding: 14px 14px 16px; } .card-footer { padding: 10px 14px 14px; } }
    .mobile-nav { display: none; position: fixed; top: 60px; left: 0; right: 0; background: #fff; border-bottom: 1px solid #e0e0e0; padding: 16px 24px; flex-direction: column; gap: 14px; z-index: 99; }
    .mobile-nav.open { display: flex; }
    .mobile-nav a { text-decoration: none; color: #555; font-size: 0.95rem; font-weight: 500; }
    .mobile-nav a.active { color: #4f46e5; font-weight: 700; }
  </style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <span class="nav-logo">피로그래밍</span>
    <ul class="nav-links">
      <li><a href="#">소개</a></li>
      <li><a href="#" class="active">포트폴리오</a></li>
      <li><a href="interview.html">인터뷰</a></li>
      <li><a href="#">지원하기</a></li>
    </ul>
    <div class="hamburger" id="navHamburger" onclick="toggleMobileNav()">
      <span></span><span></span><span></span>
    </div>
  </div>
</nav>
<div class="mobile-nav" id="mobileNav">
  <a href="#">소개</a>
  <a href="#" class="active">포트폴리오</a>
  <a href="interview.html">인터뷰</a>
  <a href="#">지원하기</a>
</div>
<div class="page-header">
  <h1>포트폴리오</h1>
  <p>피로그래밍 부원들이 만든 프로젝트를 소개합니다</p>
</div>
<div class="tabs">
  <button class="tab-btn">22기</button>
  <button class="tab-btn">23기</button>
  <button class="tab-btn active">24기</button>
</div>
<section class="portfolio-section">
  <div class="portfolio-grid" id="grid"></div>
</section>
<script>
  function toggleMobileNav() {
    document.getElementById('mobileNav').classList.toggle('open');
  }

  const IMG = "data:image/jpeg;base64,";

  const cards = [
    { tags: [['Django',''], ['React','blue']], title: '오늘 뭐 먹지? – 식사 추천 서비스', desc: '위치 기반으로 주변 음식점을 추천해주는 서비스. 리뷰와 평점을 기반으로 맞춤 추천을 제공합니다.', members: '👥 4명' },
    { tags: [['Flask',''], ['Vue.js','green']], title: '스터디 매칭 플랫폼', desc: '관심 분야와 목표를 입력하면 최적의 스터디 파트너를 연결해주는 매칭 플랫폼입니다.', members: '👥 3명' },
    { tags: [['FastAPI','orange'], ['Next.js','blue']], title: '러닝 크루 커뮤니티', desc: '러닝 모임을 쉽게 만들고 참여할 수 있는 커뮤니티 플랫폼. 경로 공유 및 기록 관리 기능 제공.', members: '👥 5명' },
    { tags: [['Django',''], ['React','green']], title: '무드 플레이리스트 생성기', desc: '현재 기분이나 상황을 입력하면 AI가 어울리는 플레이리스트를 생성해주는 서비스입니다.', members: '👥 4명' },
    { tags: [['Spring Boot','orange'], ['TypeScript','blue']], title: '식물 케어 다이어리', desc: '반려 식물의 물주기, 영양제 일정을 관리하고 성장 기록을 사진으로 남기는 앱입니다.', members: '👥 3명' },
    { tags: [['Django',''], ['Vue.js','green']], title: '대학생 중고 거래 플랫폼', desc: '학교 인증을 통해 신뢰할 수 있는 교내 중고 거래를 지원하는 플랫폼입니다.', members: '👥 4명' },
    { tags: [['Flask',''], ['React','blue'], ['GPT-4','orange']], title: 'AI 여행 일정 플래너', desc: '여행지, 기간, 예산을 입력하면 AI가 최적의 여행 일정을 자동으로 짜주는 서비스.', members: '👥 5명' },
    { tags: [['FastAPI',''], ['React','green']], title: '가계부 & 소비 분석 서비스', desc: '매월 지출 내역을 기록하고 카테고리별 소비 패턴을 시각화해주는 스마트 가계부.', members: '👥 3명' },
    { tags: [['Django',''], ['Next.js','blue']], title: '자취방 후기 공유 플랫폼', desc: '자취 경험자들이 실제 후기와 꿀팁을 공유하고 지역별 방 정보를 모아볼 수 있는 플랫폼.', members: '👥 4명' },
  ];

  const grid = document.getElementById('grid');
  cards.forEach(c => {
    const tagsHtml = c.tags.map(([label, cls]) => `<span class="tag ${cls}">${label}</span>`).join('');
    grid.innerHTML += `
      <div class="portfolio-card">
        <div class="card-img-wrap"><img src="${IMG}" alt="프로젝트 이미지" /></div>
        <div class="card-body">
          <div class="card-tags">${tagsHtml}</div>
          <div class="card-title">${c.title}</div>
          <div class="card-desc">${c.desc}</div>
        </div>
        <div class="card-footer">
          <span class="card-members">${c.members}</span>
          <div class="card-hamburger"><span></span><span></span><span></span></div>
        </div>
      </div>`;
  });
</script>
</body>
</html>
